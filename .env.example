# ── Email (required) ─────────────────────────────────────────────────────────
# Use a Gmail address. EMAIL_PASSWORD must be a Gmail App Password, NOT your
# normal Google login password.
# Get one at: https://myaccount.google.com/apppasswords
# (Google Account → Security → 2-Step Verification → App Passwords)

EMAIL_SENDER=support@collxct.com.ng
EMAIL_PASSWORD=Admin1234$
EMAIL_RECIPIENT=olufemi.mohammed11@gmail.com

# ── OANDA Real-time Data (optional but strongly recommended) ──────────────────
# Sign up free: https://www.oanda.com/register/#/sign-up/demo  (practice account)
# Get token: My Account → Manage API Access → Generate Token
# Account ID: shown on your OANDA dashboard (e.g. 001-004-1234567-001)
OANDA_API_KEY=your_oanda_api_token_here
OANDA_ACCOUNT_ID=your_account_id_here

# ── Account ───────────────────────────────────────────────────────────────────
ACCOUNT_BALANCE=50000

# ── Deriv.com Auto-Trading ────────────────────────────────────────────────────
# Step 1: Create a Deriv account at deriv.com
# Step 2: Go to Account Settings → API Token → Create token
#         Permissions needed: Read + Trade
# Step 3: Paste the token below

DERIV_API_TOKEN=your_deriv_api_token_here

# DERIV_DEMO=true  → trades on virtual/demo account (safe for testing)
# DERIV_DEMO=false → trades on your REAL account with real money (live)
DERIV_DEMO=true

# ── Trade Journal (smart recording + weekly reports) ──────────────────────────
# One-time setup:
#   1. Go to gist.github.com → New Gist
#   2. Filename: trade_log.csv | Leave content blank | Click "Create secret gist"
#   3. Copy the Gist ID from the URL (long hex string after your username)
#   4. GIST_TOKEN: use the same GitHub PAT you use for cron-job.org (needs "gist" scope)

TRADE_LOG_GIST_ID=92f0d1198e45ca4237c117b907d89e11
GIST_TOKEN=token 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
