# ── Email (required) ─────────────────────────────────────────────────────────
# Use a Gmail address. EMAIL_PASSWORD must be a Gmail App Password, NOT your
# normal Google login password.
# Get one at: https://myaccount.google.com/apppasswords
# (Google Account → Security → 2-Step Verification → App Passwords)

EMAIL_SENDER=support@collxct.com.ng
EMAIL_PASSWORD=Admin1234$
EMAIL_RECIPIENT=olufemi.mohammed11@gmail.com

# ── Account ───────────────────────────────────────────────────────────────────
ACCOUNT_BALANCE=50000

# ── IQ Option Auto-Trading ────────────────────────────────────────────────────
# Sign up free: https://iqoption.com
# Demo account starts with $10,000 virtual — set IQ_DEMO=true to use it
# IQ_DEMO=false switches to your real-money account (use with caution!)

IQ_EMAIL=your_iqoption_email@example.com
IQ_PASSWORD=your_iqoption_password
IQ_DEMO=true

# ── Trade Journal (smart recording + weekly reports) ──────────────────────────
# One-time setup:
#   1. Go to gist.github.com → New Gist
#   2. Filename: trade_log.csv | Leave content blank | Click "Create secret gist"
#   3. Copy the Gist ID from the URL (long hex string after your username)
#   4. GIST_TOKEN: use the same GitHub PAT you use for cron-job.org (needs "gist" scope)

TRADE_LOG_GIST_ID=your_gist_id_here
GIST_TOKEN=github_pat_your_token_here
